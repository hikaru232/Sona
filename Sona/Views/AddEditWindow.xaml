<Window x:Class="Sona.Views.AddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sona.Views"
        mc:Ignorable="d"
        Title="{Binding EditOrAdd}" Height="450" Width="800"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <StackPanel MaxWidth="400">
            <TextBlock Text="名前" FontSize="12"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalAlignment="Center"
                     Width="400" Height="20" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding Volume, StringFormat=音量: {0}%}" FontSize="12"/>
            <Slider Value="{Binding Volume}"
                    Minimum="0" Maximum="100"
                    Width="400"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1"
                    Margin="0,0,0,10"
                    IsMoveToPointEnabled="True"/>
            <TextBlock Text="ファイル" FontSize="12"/>
            <TextBox Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"  FontSize="14" VerticalAlignment="Center"
                     Width="400" Height="20" Margin="0,0,0,10"/>
        </StackPanel>

        <DockPanel>
            <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="60" Margin="0,20,0,0">
                <!--ここのContentはとりあえず保存で-->
                <Button Content="キャンセル" Command="{Binding CancelCommand}"
                        Width="100" Height="40"/>
                <Button Content="保存" Command="{Binding SaveCommand}"
                        Width="100" Height="40"/>
            </UniformGrid>
        </DockPanel>
    </StackPanel>
</Window>
