<Window x:Class="Sona.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sona"
        mc:Ignorable="d"
        Title="Sona" Height="800" Width="1200"
        MinHeight="600" MinWidth="400">

        <DockPanel Margin="20">
            <UniformGrid DockPanel.Dock="Bottom" Columns="3" Height="60" Margin="0,20,0,0" MaxWidth="600">
                <Button Content="Sona" Command="{Binding ShowSoundPadCommand}"
                        Width="100" Height="40"/>
                <Button Content="設定" Command="{Binding ShowSettingsCommand}"
                        Width="100" Height="40"/>
                <Button Content="追加" Command="{Binding ShowAddDialogCommand}"
                        Width="100" Height="40"/>
            </UniformGrid>

            <ContentControl Content="{Binding CurrentPage}"/>
        </DockPanel>
</Window>
