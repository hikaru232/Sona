<Window x:Class="Sona.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sona"
        mc:Ignorable="d"
        Title="Sona" Height="800" Width="1200"
        MinHeight="300" MinWidth="400">

    <StackPanel Margin="20">
        <ContentControl Content="{Binding CurrentPage}"/>
        
        <DockPanel>
            <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="60" Margin="0,20,0,0">
                <Button Content="追加" Command="{Binding ShowAddDialogCommand}"
                        Width="100" Height="40"/>
                <Button Content="追加" Command="{Binding ShowAddDialogCommand}"
                        Width="100" Height="40"/>
            </UniformGrid>
        </DockPanel>
    </StackPanel>
</Window>
