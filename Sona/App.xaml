<Application x:Class="Sona.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Sona"
             xmlns:vm="clr-namespace:Sona.ViewModels"
             xmlns:view="clr-namespace:Sona.Views"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <DataTemplate DataType="{x:Type vm:SoundPadViewModel}">
            <view:SoundPadView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <view:SettingsView/>
        </DataTemplate>

        <!--<DataTemplate DataType="{x:Type vm:ManagementViewModel}">
    <view:ManagementView/>
</DataTemplate>
-->
    </Application.Resources>
</Application>
